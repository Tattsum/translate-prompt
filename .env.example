# LLM（App-2）— コピーして .env にリネームし、値を埋める。コミットしないこと。
# 手順: docs/llm-setup.md

# マスタースイッチ（未設定時は false）
LLM_ENABLED=true

# Gemini（codex / openai / devin / cursor プロファイル）
GOOGLE_API_KEY=
# GEMINI_API_KEY=   # GOOGLE_API_KEY の別名

# Anthropic（claude プロファイル）
# ANTHROPIC_API_KEY=

# 任意
# LLM_DEFAULT_MAX_CALLS=3
# LLM_GEMINI_MODEL=gemini-2.5-flash
# LLM_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# サーバー（既存）
# LISTEN_HOST=127.0.0.1
# PORT=8080
# INVESTIGATE_ENABLED=true
# ALLOWED_ORIGINS=*
